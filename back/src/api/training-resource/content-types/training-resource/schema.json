{
  "kind": "collectionType",
  "collectionName": "training_resources",
  "info": {
    "singularName": "training-resource",
    "pluralName": "training-resources",
    "displayName": "TrainingResource"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "richtext",
      "required": true
    },
    "image": {
      "allowedTypes": [
        "images"
      ],
      "type": "media",
      "multiple": true,
      "required": true
    },
    "videoPlayListLink": {
      "type": "string",
      "required": true
    },
    "web_articles": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::web-article.web-article",
      "inversedBy": "training_resources"
    }
  }
}
